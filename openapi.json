{
  "openapi": "3.0.3",
  "info": {
    "title": "Trade Route Tracker API",
    "description": "API para seguimiento de rutas y visitas en terreno de Trade Marketing On Trade.",
    "version": "1.0.0",
    "contact": {
      "name": "Trade Route Tracker",
      "url": "https://github.com/pipe18t/trade-route-tracker"
    }
  },
  "servers": [
    { "url": "http://localhost:3000", "description": "Desarrollo local" },
    { "url": "https://trade-route-tracker.vercel.app", "description": "Producción (Vercel)" }
  ],
  "security": [{ "cookieAuth": [] }],
  "paths": {
    "/auth/callback": {
      "get": {
        "summary": "Intercambiar código OTP/OAuth por sesión",
        "operationId": "authCallback",
        "tags": ["Auth"],
        "parameters": [
          { "name": "code", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "next", "in": "query", "schema": { "type": "string", "default": "/dashboard" } }
        ],
        "responses": {
          "302": { "description": "Redirección a /dashboard o /login?error=oauth_callback_failed" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Cerrar sesión",
        "operationId": "logout",
        "tags": ["Auth"],
        "responses": { "302": { "description": "Redirección a /login" } }
      }
    },
    "/clientes": {
      "get": {
        "summary": "Listar clientes",
        "operationId": "getClientes",
        "tags": ["Clientes"],
        "parameters": [
          { "name": "region", "in": "query", "schema": { "type": "string", "enum": ["RM", "V"] } },
          { "name": "zone_id", "in": "query", "schema": { "type": "string", "format": "uuid" } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["pendiente", "visitado", "seguimiento", "no_atendido", "coordinar_hora", "administrador_no_disponible"] } },
          { "name": "priority", "in": "query", "schema": { "type": "string", "enum": ["alta", "media", "baja"] } },
          { "name": "search", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Página HTML con tabla de clientes" } }
      }
    },
    "/clientes/nuevo": {
      "get": { "summary": "Formulario nuevo cliente", "tags": ["Clientes"], "responses": { "200": { "description": "Página con formulario de creación" } } }
    },
    "/clientes/{id}": {
      "get": {
        "summary": "Ficha del local",
        "tags": ["Clientes"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "Página con datos, historial y fotos" } }
      }
    },
    "/clientes/{id}/editar": {
      "get": {
        "summary": "Formulario editar cliente",
        "tags": ["Clientes"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "Página con formulario de edición" } }
      }
    },
    "/clientes/{id}/nueva-visita": {
      "get": {
        "summary": "Formulario registrar visita",
        "tags": ["Visitas"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "Página con formulario de 7 secciones" } }
      }
    },
    "/rutas": {
      "get": { "summary": "Listar rutas", "tags": ["Rutas"], "responses": { "200": { "description": "Página con lista de rutas" } } }
    },
    "/rutas/nueva": {
      "get": { "summary": "Formulario nueva ruta", "tags": ["Rutas"], "responses": { "200": { "description": "Página de creación de ruta" } } }
    },
    "/rutas/{id}": {
      "get": {
        "summary": "Detalle de ruta",
        "tags": ["Rutas"],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
        "responses": { "200": { "description": "Página con detalle y link Google Maps" } }
      }
    },
    "/reportes/semanal": {
      "get": { "summary": "Generador de reporte semanal", "tags": ["Reportes"], "responses": { "200": { "description": "Página con filtros y reporte generado" } } }
    },
    "/importar": {
      "get": { "summary": "Importación CSV", "tags": ["Importar"], "responses": { "200": { "description": "Página con upload y preview" } } }
    },
    "/configuracion/zonas": {
      "get": { "summary": "CRUD de zonas", "tags": ["Configuración"], "responses": { "200": { "description": "Página con lista de zonas por región" } } }
    },
    "/panel": {
      "get": { "summary": "Panel de control técnico", "tags": ["Sistema"], "responses": { "200": { "description": "Página con estadísticas DB, rutas, stack" } } }
    },
    "/dashboard": {
      "get": { "summary": "Dashboard principal", "tags": ["Dashboard"], "responses": { "200": { "description": "Página con KPIs y gráficos" } } }
    }
  },
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "sb-auth-token",
        "description": "Cookie de sesión de Supabase"
      }
    },
    "schemas": {
      "Client": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "address": { "type": "string", "nullable": true },
          "region": { "type": "string" },
          "comuna": { "type": "string", "nullable": true },
          "zone_id": { "type": "string", "format": "uuid", "nullable": true },
          "priority": { "type": "string", "enum": ["alta", "media", "baja"] },
          "status": { "type": "string", "enum": ["pendiente", "visitado", "seguimiento", "no_atendido", "coordinar_hora", "administrador_no_disponible"] }
        }
      },
      "Visit": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "client_id": { "type": "string", "format": "uuid" },
          "user_id": { "type": "string", "format": "uuid" },
          "visit_date": { "type": "string", "format": "date" },
          "visit_time": { "type": "string", "format": "time", "nullable": true },
          "contact_name": { "type": "string", "nullable": true },
          "could_talk": { "type": "boolean", "nullable": true },
          "final_status": { "type": "string", "enum": ["visitado", "seguimiento", "no_atendido", "coordinar_hora", "administrador_no_disponible"] },
          "pop_material": { "type": "array", "items": { "type": "string" } },
          "opportunity_type": { "type": "array", "items": { "type": "string" } }
        }
      },
      "Zone": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "region": { "type": "string", "enum": ["RM", "V"] },
          "description": { "type": "string", "nullable": true }
        }
      },
      "Route": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "region": { "type": "string", "nullable": true },
          "zone_id": { "type": "string", "format": "uuid", "nullable": true },
          "route_date": { "type": "string", "format": "date", "nullable": true },
          "status": { "type": "string", "enum": ["planificada", "en_progreso", "completada", "cancelada"] }
        }
      },
      "WeeklyReport": {
        "type": "object",
        "properties": {
          "startDate": { "type": "string", "format": "date" },
          "endDate": { "type": "string", "format": "date" },
          "userName": { "type": "string" },
          "region": { "type": "string" },
          "zones": { "type": "string" },
          "stats": {
            "type": "object",
            "properties": {
              "totalVisits": { "type": "integer" },
              "seguimiento": { "type": "integer" },
              "noAtendidos": { "type": "integer" },
              "conOportunidad": { "type": "integer" }
            }
          },
          "opportunities": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "tags": [
    { "name": "Auth" },
    { "name": "Dashboard" },
    { "name": "Clientes" },
    { "name": "Visitas" },
    { "name": "Rutas" },
    { "name": "Reportes" },
    { "name": "Importar" },
    { "name": "Configuración" },
    { "name": "Sistema" }
  ]
}
